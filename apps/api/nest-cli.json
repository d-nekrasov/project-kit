{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "core/lang/**/*.json",
        "watchAssets": true
      },
      {
        "include": "modules/**/lang/**/*.json",
        "watchAssets": true
      }
    ]
  }
}
