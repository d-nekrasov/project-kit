APP_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/project_kit?schema=public
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# One-time token guarding POST /api/installer/setup while the system is not installed.
# The client must send it in the X-Install-Token header.
# Generate with: openssl rand -hex 32
# production: required until installation completes — setup returns 403 without it
# (startup is NOT blocked, so an already installed system runs fine without the variable).
# development/test: optional; a startup warning is logged if unset while not installed.
# After a successful installation remove INSTALL_TOKEN from the environment and restart.
INSTALL_TOKEN=
# Generate with: openssl rand -base64 48
# Must be at least 32 bytes; weak/default values fail startup in production.
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
AUTH_COOKIE_NAME=project_kit_auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=strict
AUTH_BEARER_ENABLED=true
CSRF_COOKIE_NAME=XSRF-TOKEN
CSRF_HEADER_NAME=X-CSRF-Token
# Optional key for signing CSRF tokens (signed double-submit, HMAC-SHA256).
# Generate with: openssl rand -base64 32
# When empty, a key is derived from JWT_SECRET via HMAC-SHA256(JWT_SECRET, "csrf-key-v1").
CSRF_SECRET=
AUTH_PASSWORD_RESET_URL=http://localhost:3000/reset-password
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
# Short cache for the per-request current user lookup (roles, memberships).
# Trade-off: permission/status changes (block, role revoke) take effect with up to this delay
# unless explicitly invalidated. 0 = cache disabled.
# With MULTI_INSTANCE=true the cache requires Redis; without Redis it is silently disabled.
AUTH_CURRENT_USER_CACHE_TTL_MS=10000
# Generate with: openssl rand -base64 32
# Changing this key after encrypted connector secrets were saved makes existing secrets undecryptable until they are re-encrypted with rotation/backfill.
CONFIG_ENCRYPTION_KEY=
CASBIN_MODEL_PATH=src/infrastructure/casbin/model.conf

TRUST_PROXY=false
# development/test: Redis optional, defaults to in-memory auth rate limit and token blacklist
# production: REDIS_ENABLED=true and REDIS_URL are required, no in-memory fallback
MULTI_INSTANCE=false
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
# Casbin policy changes are synced between API instances via Redis pub/sub when Redis is enabled
# production with MULTI_INSTANCE=true: REDIS_ENABLED=true and REDIS_URL are required
# Safety net: periodic full policy reload in ms to recover missed pub/sub events, 0 = disabled
CASBIN_POLICY_RELOAD_INTERVAL_MS=0

# --- Data retention (src/core/data-retention) ---
# Periodic background cleanup deletes old rows from SystemLog, AuditLog and
# Notification (only status=READ; NotificationDelivery rows are removed by the
# database via ON DELETE CASCADE). Used or expired PasswordResetToken rows older
# than 30 days are always cleaned as well.
# Values are days to keep rows. 0 = retention DISABLED for that entity (rows are
# kept forever). When a variable is NOT set, the defaults below apply — i.e.
# cleanup is enabled by default.
RETENTION_SYSTEM_LOGS_DAYS=90
RETENTION_AUDIT_LOGS_DAYS=365
RETENTION_NOTIFICATIONS_DAYS=90
# How often the cleanup runs (also runs once on startup). 0 = background cleanup
# fully disabled. Deletes happen in batches of RETENTION_CLEANUP_BATCH_SIZE rows
# with a short pause in between, so no long-running transaction is held.
# Multi-instance safe: a Postgres advisory lock guarantees only one instance
# runs the cleanup at a time; the others skip the cycle.
# Note: the cleanup writes its own run summaries to SystemLog (source
# data_retention) — those records are subject to SystemLog retention too.
RETENTION_CLEANUP_INTERVAL_MS=3600000
RETENTION_CLEANUP_BATCH_SIZE=5000

SSE_MAX_CLIENTS=1000
SSE_MAX_CLIENTS_PER_USER=5
SSE_HEARTBEAT_INTERVAL_MS=25000
